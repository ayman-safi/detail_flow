[Unit]
Description=DetailFlow encrypted PostgreSQL backup to Cloudflare R2
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/detailflow
ExecStart=/bin/bash /opt/detailflow/deploy/backup.sh
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=7

[Install]
WantedBy=multi-user.target
