# Cloudflare R2 S3 endpoint and a repository prefix dedicated to DetailFlow.
RESTIC_REPOSITORY=s3:https://ACCOUNT_ID.r2.cloudflarestorage.com/detailflow-db-backups/detailflow
RESTIC_PASSWORD=replace-with-a-long-random-backup-password
AWS_ACCESS_KEY_ID=replace-with-r2-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
AWS_DEFAULT_REGION=auto
